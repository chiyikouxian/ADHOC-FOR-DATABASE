# Compose environment example

# PostgreSQL
PG_DB=fanet
PG_USER=fanet_app
PG_PASSWORD=fanet_dev_pwd

# TDengine
TD_HOST=127.0.0.1
TD_REST_PORT=6041

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# MQTT
MQTT_HOST=127.0.0.1
MQTT_PORT=1883

# Backend runtime
BACKEND_PORT=18080
JWT_SECRET=replace-with-a-unique-random-secret-at-least-32-bytes-long

# LLM
LLM_API_BASE=https://api.deepseek.com
LLM_API_KEY=sk-your-key-here
LLM_MODEL=deepseek-chat

# Optional read-only credentials for NL2SQL
PG_RO_USER=fanet_ro
PG_RO_PASSWORD=change_me_readonly
