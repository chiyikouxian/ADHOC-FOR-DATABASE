# =============================================================
# FANET 平台 — 环境变量样例
# 用法：复制为 .env（同目录），docker compose 会自动读取
# .env 已在 .gitignore 中，禁止提交真实口令/Key
# =============================================================

# ---------- PostgreSQL（关系核心库）----------
PG_DB=fanet
PG_USER=fanet_app
PG_PASSWORD=change_me_in_real_env     # 开发可用，上线必须改

# ---------- TDengine（遥测时序库）----------
# 容器内默认无需账号口令；JDBC-RESTful 走 6041 端口
TD_HOST=127.0.0.1
TD_REST_PORT=6041

# ---------- Redis ----------
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# ---------- MQTT（EMQX，S3 用）----------
MQTT_HOST=127.0.0.1
MQTT_PORT=1883

# ---------- 大模型 API（NL2SQL 用）----------
LLM_API_BASE=https://api.deepseek.com
LLM_API_KEY=                          # 填你的 DeepSeek API Key，严禁提交 Git

# ---------- NL2SQL 只读账号（防注入，S6 用）----------
PG_RO_USER=fanet_ro
PG_RO_PASSWORD=change_me_readonly
